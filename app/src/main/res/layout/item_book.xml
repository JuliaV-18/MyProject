<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:background="@color/background"
    xmlns:app="http://schemas.android.com/apk/res-auto">



    <ImageView
        android:id="@+id/img_book_cover"
        android:layout_width="150dp"
        android:layout_height="200dp"
        android:background="@color/background_2"
        android:scaleType="centerCrop" />


    <LinearLayout
        android:layout_width="205dp"
        android:layout_height="123dp"
        android:orientation="vertical">


        <TextView
            android:id="@+id/tv_item_book_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="A Cool Book"
            android:textColor="@color/txt2"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="by "
                android:textColor="@color/txt1"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_item_book_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="John Doe"
                android:textColor="@color/txt3"
                android:textSize="14sp"
                tools:text="@tools:sample/full_names"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_item_book_copies"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/txt3"
                android:textSize="14sp"
                android:text="45" />

        </LinearLayout>


        <TextView
            android:id="@+id/tv_item_book_genre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TextView" />




    </LinearLayout>




</LinearLayout>