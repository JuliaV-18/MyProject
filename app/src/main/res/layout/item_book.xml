<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:background="@color/light"
    android:paddingVertical="5dp"
    android:dividerPadding="5dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">



    <ImageView
        android:id="@+id/img_book_cover"
        android:layout_width="150dp"
        android:layout_height="match_parent"
        android:background="@color/background2"
        android:scaleType="centerCrop" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="20dp"
        android:orientation="vertical"
        android:background="@color/background">


        <TextView
            android:id="@+id/tv_item_book_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="A Cool Book"
            android:textColor="@color/txt2"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="by "
                android:textColor="@color/txt1"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_item_book_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="John Doe"
                android:textColor="@color/txt3"
                android:textSize="20sp"
                tools:text="@tools:sample/full_names" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Copies: "
                android:textColor="@color/txt1"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_item_book_copies"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="45"
                android:textColor="@color/txt3"
                android:textSize="20sp" />

        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Genre: "
                android:textColor="@color/txt1"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_item_book_genre"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:textColor="@color/txt3"
                android:text="GENRE"
                android:textSize="20dp"/>
        </LinearLayout>





    </LinearLayout>




</LinearLayout>