<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ProfileLoan">


    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="39dp"
        android:text="LOAN DETAILS"
        android:textSize="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_return_loan_user_name"
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:layout_marginStart="61dp"
        android:layout_marginTop="21dp"
        android:layout_marginEnd="61dp"
        android:layout_marginBottom="38dp"
        android:text="User's name:"
        app:layout_constraintBottom_toBottomOf="@+id/tv_return_loan_book_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3" />

    <TextView
        android:id="@+id/tv_return_loan_book_name"
        android:layout_width="0dp"
        android:layout_height="38dp"
        android:layout_marginStart="61dp"
        android:layout_marginTop="59dp"
        android:layout_marginEnd="61dp"
        android:layout_marginBottom="55dp"
        android:text="Book title: "
        app:layout_constraintBottom_toBottomOf="@+id/tv_borrow_date"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3" />



    <TextView
        android:id="@+id/textview6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginTop="192dp"
        android:text="Date Borrowed"
        app:layout_constraintStart_toStartOf="@+id/tv_return_loan_book_name"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_borrow_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="51dp"
        android:layout_marginTop="212dp"
        android:text="TextView"
        app:layout_constraintStart_toStartOf="@+id/tv_return_loan_book_name"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/textview5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="160dp"
        android:layout_marginTop="192dp"
        android:text="Date for Return"
        app:layout_constraintStart_toStartOf="@+id/tv_return_loan_book_name"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_return_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="55dp"
        android:text="TextView"
        app:layout_constraintEnd_toEndOf="@+id/tv_return_loan_book_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_return_loan_book_name" />




    <Button
        android:id="@+id/btn_cancel_loan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="11dp"
        android:text="Cancel"
        app:layout_constraintBaseline_toBaselineOf="@+id/btn_return_book"
        app:layout_constraintEnd_toStartOf="@+id/btn_return_book"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_return_book"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="252dp"
        android:text="Return"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_cancel_loan" />


    <TextView
        android:id="@+id/tv_user_extra_time"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginStart="61dp"
        android:layout_marginEnd="34dp"
        android:layout_marginBottom="87dp"
        android:text="Have you not finished reading?"
        android:textSize="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btn_extra_time"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_extra_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="21dp"
        android:layout_marginEnd="61dp"
        android:text="Extra Time"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/tv_user_extra_time"
        app:layout_constraintTop_toTopOf="@+id/tv_user_extra_time" />
</androidx.constraintlayout.widget.ConstraintLayout>